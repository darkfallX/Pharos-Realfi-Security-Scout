NODE_ENV=development

PORT=8787



# Public base URL for SKILL.md / agent entrypoint (no trailing slash)

SERVER_URL=http://localhost:8787



# Pharos mainnet

PHAROS_RPC=https://rpc.pharos.xyz

PHAROS_CHAIN_ID=1672



# Official USDC on Pharos

USDC_ADDRESS=0xC879C018dB60520F4355C26eD1a6D572cdAC1815

USDC_NAME=USDC



# Where x402 scan micro-fees are sent

PAY_TO_ADDRESS=0xee9714646473902a4d82de393fe01a5dc446d049

SCAN_FEE_USDC=0.010000



# Self-hosted x402 facilitator (run: npm run start:facilitator)

FACILITATOR_URL=http://localhost:3001

FACILITATOR_PORT=3001



# Facilitator signer + x402 payer for npm run test:x402:scan
# Must hold USDC (pays ~0.01/scan) and PHRS (gas) on Pharos mainnet. Format: 0x + 64 hex chars.
EVM_PRIVATE_KEY=



# Optional facilitator API key

X402_FACILITATOR_API_KEY=



# Legacy alias for FACILITATOR_URL (optional)

X402_VERIFY_URL=



# Optional signing key (legacy name; prefer EVM_PRIVATE_KEY for facilitator)

PRIVATE_KEY=



# Local dev only: accept x-payment-proof values prefixed with dev_



X402_ALLOW_INSECURE_DEV=true



# API protection

RATE_LIMIT_WINDOW_MS=60000

RATE_LIMIT_MAX=30

