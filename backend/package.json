{
  "name": "pharos-realfi-security-scout-backend",
  "version": "1.0.0",
  "description": "x402-protected smart contract and RealFi risk scanner for Pharos mainnet",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:facilitator": "tsx src/facilitator.ts",
    "start:facilitator:prod": "node dist/facilitator.js",
    "test:x402:scan": "tsx src/scripts/x402-scan-client.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "pharos",
    "realfi",
    "security",
    "x402",
    "usdc",
    "ai-agent"
  ],
  "author": "Pharos Skill Builder",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "@x402/express": "^2.13.0",
    "@x402/fetch": "^2.13.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "viem": "^2.48.11",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
